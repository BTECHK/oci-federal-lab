          <mxGeometry x="770" y="1395" width="470" height="55" as="geometry" />
        </mxCell>
        <mxCell id="layerAppPkg" value="&lt;font color=&quot;#FFFFFF&quot; style=&quot;font-family:Consolas;&quot;&gt;&lt;b&gt;App Packages:&lt;/b&gt; fastapi, uvicorn&lt;br&gt;RUN pip install -r requirements.txt&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#3a3a7a;strokeColor=#6a6aba;strokeWidth=1;" vertex="1" parent="1">
          <mxGeometry x="770" y="1460" width="470" height="55" as="geometry" />
        </mxCell>
        <mxCell id="layerAppCode" value="&lt;font color=&quot;#FFFFFF&quot; style=&quot;font-family:Consolas;&quot;&gt;&lt;b&gt;App Code:&lt;/b&gt; main.py&lt;br&gt;COPY ./app /app&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#3a3a8a;strokeColor=#6a6aca;strokeWidth=1;" vertex="1" parent="1">
          <mxGeometry x="770" y="1525" width="470" height="55" as="geometry" />
        </mxCell>
        <mxCell id="layerUser" value="&lt;font color=&quot;#FFFFFF&quot; style=&quot;font-family:Consolas;&quot;&gt;&lt;b&gt;User:&lt;/b&gt; appuser (non-root)&lt;br&gt;USER appuser — security best practice&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#3a3a9a;strokeColor=#6a6ada;strokeWidth=1;" vertex="1" parent="1">
          <mxGeometry x="770" y="1590" width="470" height="55" as="geometry" />
        </mxCell>
        <mxCell id="layerPort" value="&lt;font color=&quot;#FFFFFF&quot; style=&quot;font-family:Consolas;&quot;&gt;&lt;b&gt;EXPOSE 8000&lt;/b&gt;&lt;br&gt;CMD [&quot;uvicorn&quot;, &quot;main:app&quot;, &quot;--host&quot;, &quot;0.0.0.0&quot;, &quot;--port&quot;, &quot;8000&quot;]&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#3a3aaa;strokeColor=#6a6aea;strokeWidth=1;" vertex="1" parent="1">
          <mxGeometry x="770" y="1655" width="470" height="55" as="geometry" />
        </mxCell>

        <!-- Container endpoints -->
        <mxCell id="containerEndpoints" value="&lt;font color=&quot;#00E5CC&quot; style=&quot;font-family:Consolas;font-size:12px;&quot;&gt;&lt;b&gt;Endpoints:&lt;/b&gt;&lt;br&gt;GET /health      → {&quot;status&quot;: &quot;healthy&quot;}&lt;br&gt;GET /personnel   → [{...employee data...}]&lt;br&gt;GET /compliance  → FedRAMP status&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1a2e2e;strokeColor=#00B4AA;strokeWidth=1;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="770" y="1730" width="470" height="85" as="geometry" />
        </mxCell>

        <!-- Container test command -->
        <mxCell id="containerTest" value="&lt;font color=&quot;#AAAAAA&quot; style=&quot;font-family:Consolas;font-size:11px;&quot;&gt;Test from Windows: &lt;b&gt;curl http://localhost:8000/health&lt;/b&gt;&lt;br&gt;Works because Docker maps port through to Windows localhost&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2a2a3a;strokeColor=#555577;strokeWidth=1;" vertex="1" parent="1">
          <mxGeometry x="770" y="1830" width="470" height="50" as="geometry" />
        </mxCell>

        <!-- ==================== -->
        <!-- KEY CALLOUTS (LEFT HALF) -->
        <!-- ==================== -->
        <mxCell id="callout1" value="&lt;font color=&quot;#FF6B6B&quot; style=&quot;font-size:12px;&quot;&gt;&lt;b&gt;Git Bash is NOT Linux&lt;/b&gt; — it is a translation layer on Windows.&lt;br&gt;Looks like bash, but no fork(), no real kernel.&lt;br&gt;Ansible will FAIL if you try to run it from Git Bash.&lt;/font&gt;" style="shape=callout;whiteSpace=wrap;html=1;perimeter=calloutPerimeter;size=30;position=0.3;position2=1;base=25;rounded=1;fillColor=#3a1a1a;strokeColor=#FF6B6B;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="110" y="2850" width="420" height="80" as="geometry" />
        </mxCell>

        <mxCell id="callout2" value="&lt;font color=&quot;#90EE90&quot; style=&quot;font-size:12px;&quot;&gt;&lt;b&gt;WSL2 IS Linux&lt;/b&gt; — full kernel, real syscalls.&lt;br&gt;That is why Ansible &lt;b&gt;only&lt;/b&gt; works here.&lt;br&gt;Use &lt;font style=&quot;font-family:Consolas;&quot;&gt;ProxyCommand&lt;/font&gt; (not ProxyJump) for SSH.&lt;/font&gt;" style="shape=callout;whiteSpace=wrap;html=1;perimeter=calloutPerimeter;size=30;position=0.7;position2=0;base=25;rounded=1;fillColor=#1a3a1a;strokeColor=#90EE90;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="110" y="1640" width="380" height="80" as="geometry" />
        </mxCell>

        <mxCell id="callout3" value="&lt;font color=&quot;#00E5CC&quot; style=&quot;font-size:12px;&quot;&gt;&lt;b&gt;Docker Desktop looks Windows-native&lt;/b&gt;, but containers&lt;br&gt;actually run inside a hidden Hyper-V VM.&lt;br&gt;The Docker CLI on Windows talks to a daemon in the VM.&lt;/font&gt;" style="shape=callout;whiteSpace=wrap;html=1;perimeter=calloutPerimeter;size=30;position=0.3;position2=0;base=25;rounded=1;fillColor=#1a2e2e;strokeColor=#00E5CC;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="110" y="1940" width="440" height="80" as="geometry" />
        </mxCell>

        <mxCell id="callout4" value="&lt;font color=&quot;#FFD700&quot; style=&quot;font-size:12px;&quot;&gt;&lt;b&gt;Shared filesystem — same files, two paths:&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-family:Consolas;&quot;&gt;Windows: C:\Users\&lt;your-windows-username&gt;\...\oci-federal-lab&lt;br&gt;WSL2:&amp;nbsp;&amp;nbsp; /mnt/c/Users/&lt;your-windows-username&gt;/.../oci-federal-lab&lt;/font&gt;&lt;/font&gt;" style="shape=callout;whiteSpace=wrap;html=1;perimeter=calloutPerimeter;size=30;position=0.5;position2=1;base=25;rounded=1;fillColor=#2e2e1a;strokeColor=#FFD700;strokeWidth=2;align=left;spacingLeft=15;" vertex="1" parent="1">
          <mxGeometry x="110" y="2050" width="500" height="80" as="geometry" />
        </mxCell>

        <!-- Arrows between layers -->
        <!-- Hardware to Windows -->
        <mxCell id="arrowHWtoWin" value="" style="endArrow=block;endFill=1;strokeColor=#AAAAAA;strokeWidth=2;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="705" y="3100" as="sourcePoint" />
            <mxPoint x="705" y="3075" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="arrowHWtoWinLabel" value="&lt;font color=&quot;#AAAAAA&quot; style=&quot;font-size:11px;&quot;&gt;runs on&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=0;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="715" y="3080" width="60" height="20" as="geometry" />
        </mxCell>

        <!-- Windows to Hyper-V -->
        <mxCell id="arrowWinToHV" value="" style="endArrow=block;endFill=1;strokeColor=#AAAAAA;strokeWidth=2;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="705" y="2550" as="sourcePoint" />
            <mxPoint x="705" y="2525" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="arrowWinToHVLabel" value="&lt;font color=&quot;#AAAAAA&quot; style=&quot;font-size:11px;&quot;&gt;Hyper-V manages VMs&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=0;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="715" y="2525" width="150" height="20" as="geometry" />
        </mxCell>

        <!-- ============================================================ -->
        <!-- RIGHT HALF: OSI MODEL -->
        <!-- ============================================================ -->

        <!-- ==================== -->
        <!-- OSI Layer 7 — Application -->
        <!-- ==================== -->
        <mxCell id="osiL7Group" value="&lt;font style=&quot;font-size:15px;color:#FFFFFF;&quot;&gt;&lt;b&gt;Layer 7 — APPLICATION&lt;/b&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E84D4D;strokeColor=#CC3333;strokeWidth=3;verticalAlign=top;spacingTop=5;arcSize=8;opacity=90;" vertex="1" parent="1">
          <mxGeometry x="1420" y="160" width="680" height="310" as="geometry" />
        </mxCell>
        <mxCell id="l7curl" value="&lt;font color=&quot;#FFFFFF&quot; style=&quot;font-family:Consolas;&quot;&gt;&lt;b&gt;curl&lt;/b&gt;&lt;br&gt;HTTP requests to&lt;br&gt;/health, /personnel&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#CC3333;strokeColor=#AA2222;strokeWidth=1;" vertex="1" parent="1">
          <mxGeometry x="1440" y="210" width="150" height="65" as="geometry" />
        </mxCell>
        <mxCell id="l7fastapi" value="&lt;font color=&quot;#FFFFFF&quot; style=&quot;font-family:Consolas;&quot;&gt;&lt;b&gt;FastAPI&lt;/b&gt;&lt;br&gt;Serves endpoints&lt;br&gt;/health, /personnel&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#CC3333;strokeColor=#AA2222;strokeWidth=1;" vertex="1" parent="1">
          <mxGeometry x="1605" y="210" width="150" height="65" as="geometry" />
        </mxCell>
        <mxCell id="l7ansible" value="&lt;font color=&quot;#FFFFFF&quot; style=&quot;font-family:Consolas;&quot;&gt;&lt;b&gt;Ansible Playbooks&lt;/b&gt;&lt;br&gt;Install packages&lt;br&gt;Copy files, configure&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#CC3333;strokeColor=#AA2222;strokeWidth=1;" vertex="1" parent="1">
          <mxGeometry x="1770" y="210" width="160" height="65" as="geometry" />
        </mxCell>
        <mxCell id="l7terraform" value="&lt;font color=&quot;#FFFFFF&quot; style=&quot;font-family:Consolas;&quot;&gt;&lt;b&gt;Terraform&lt;/b&gt;&lt;br&gt;OCI provider&lt;br&gt;REST API calls&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#CC3333;strokeColor=#AA2222;strokeWidth=1;" vertex="1" parent="1">
          <mxGeometry x="1945" y="210" width="140" height="65" as="geometry" />
        </mxCell>
        <mxCell id="l7docker" value="&lt;font color=&quot;#FFFFFF&quot; style=&quot;font-family:Consolas;&quot;&gt;&lt;b&gt;docker build / docker run&lt;/b&gt;&lt;br&gt;Build images, run containers&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#CC3333;strokeColor=#AA2222;strokeWidth=1;" vertex="1" parent="1">
          <mxGeometry x="1440" y="290" width="280" height="50" as="geometry" />
        </mxCell>
        <mxCell id="l7proto" value="&lt;font color=&quot;#FFCCCC&quot; style=&quot;font-size:12px;&quot;&gt;&lt;b&gt;Protocols:&lt;/b&gt; HTTP / HTTPS&lt;br&gt;Application-level commands and responses&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=0;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="1440" y="360" width="350" height="40" as="geometry" />
        </mxCell>

        <!-- ==================== -->
        <!-- OSI Layer 6 — Presentation -->
        <!-- ==================== -->
        <mxCell id="osiL6Group" value="&lt;font style=&quot;font-size:15px;color:#FFFFFF;&quot;&gt;&lt;b&gt;Layer 6 — PRESENTATION&lt;/b&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FF8C00;strokeColor=#CC7000;strokeWidth=3;verticalAlign=top;spacingTop=5;arcSize=8;opacity=90;" vertex="1" parent="1">
          <mxGeometry x="1420" y="490" width="680" height="180" as="geometry" />
        </mxCell>
        <mxCell id="l6tls" value="&lt;font color=&quot;#FFFFFF&quot; style=&quot;font-family:Consolas;&quot;&gt;&lt;b&gt;TLS/SSL Encryption&lt;/b&gt;&lt;br&gt;HTTPS to OCI API endpoints&lt;br&gt;Terraform/OCI CLI use TLS 1.2+&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#CC7000;strokeColor=#AA5500;strokeWidth=1;" vertex="1" parent="1">
          <mxGeometry x="1440" y="540" width="280" height="65" as="geometry" />
        </mxCell>
        <mxCell id="l6json" value="&lt;font color=&quot;#FFFFFF&quot; style=&quot;font-family:Consolas;&quot;&gt;&lt;b&gt;JSON Encoding/Decoding&lt;/b&gt;&lt;br&gt;API request/response payloads&lt;br&gt;Terraform state files&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#CC7000;strokeColor=#AA5500;strokeWidth=1;" vertex="1" parent="1">
          <mxGeometry x="1740" y="540" width="280" height="65" as="geometry" />
        </mxCell>
        <mxCell id="l6ssh" value="&lt;font color=&quot;#FFFFFF&quot; style=&quot;font-family:Consolas;&quot;&gt;&lt;b&gt;SSH Encryption&lt;/b&gt; — Ansible → bastion → app server&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#CC7000;strokeColor=#AA5500;strokeWidth=1;" vertex="1" parent="1">
          <mxGeometry x="1440" y="618" width="400" height="35" as="geometry" />
        </mxCell>

        <!-- ==================== -->
        <!-- OSI Layer 5 — Session -->
        <!-- ==================== -->
        <mxCell id="osiL5Group" value="&lt;font style=&quot;font-size:15px;color:#1a1a2e;&quot;&gt;&lt;b&gt;Layer 5 — SESSION&lt;/b&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFC107;strokeColor=#CC9900;strokeWidth=3;verticalAlign=top;spacingTop=5;arcSize=8;opacity=90;" vertex="1" parent="1">
          <mxGeometry x="1420" y="690" width="680" height="180" as="geometry" />
        </mxCell>
        <mxCell id="l5ssh" value="&lt;font color=&quot;#1a1a2e&quot; style=&quot;font-family:Consolas;&quot;&gt;&lt;b&gt;SSH Sessions&lt;/b&gt;&lt;br&gt;Ansible opens session → runs tasks → closes&lt;br&gt;ProxyCommand chains: local → bastion → app&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8AD00;strokeColor=#CC9900;strokeWidth=1;" vertex="1" parent="1">
          <mxGeometry x="1440" y="740" width="310" height="65" as="geometry" />
        </mxCell>
        <mxCell id="l5https" value="&lt;font color=&quot;#1a1a2e&quot; style=&quot;font-family:Consolas;&quot;&gt;&lt;b&gt;HTTPS Sessions&lt;/b&gt;&lt;br&gt;Terraform → OCI API&lt;br&gt;Keep-alive connections&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8AD00;strokeColor=#CC9900;strokeWidth=1;" vertex="1" parent="1">
          <mxGeometry x="1770" y="740" width="240" height="65" as="geometry" />
        </mxCell>
        <mxCell id="l5docker" value="&lt;font color=&quot;#1a1a2e&quot; style=&quot;font-family:Consolas;&quot;&gt;&lt;b&gt;Docker API Socket&lt;/b&gt; — CLI talks to daemon in VM&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8AD00;strokeColor=#CC9900;strokeWidth=1;" vertex="1" parent="1">
          <mxGeometry x="1440" y="818" width="400" height="35" as="geometry" />
        </mxCell>

        <!-- ==================== -->
        <!-- OSI Layer 4 — Transport -->
        <!-- ==================== -->
        <mxCell id="osiL4Group" value="&lt;font style=&quot;font-size:15px;color:#FFFFFF;&quot;&gt;&lt;b&gt;Layer 4 — TRANSPORT&lt;/b&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#4CAF50;strokeColor=#388E3C;strokeWidth=3;verticalAlign=top;spacingTop=5;arcSize=8;opacity=90;" vertex="1" parent="1">
          <mxGeometry x="1420" y="890" width="680" height="220" as="geometry" />
        </mxCell>
        <mxCell id="l4ssh" value="&lt;font color=&quot;#FFFFFF&quot; style=&quot;font-family:Consolas;&quot;&gt;&lt;b&gt;TCP port 22&lt;/b&gt;&lt;br&gt;SSH — Ansible, manual SSH&lt;br&gt;Bastion + app server&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2E7D32;strokeColor=#1B5E20;strokeWidth=1;" vertex="1" parent="1">
          <mxGeometry x="1440" y="940" width="200" height="70" as="geometry" />
        </mxCell>
        <mxCell id="l4app" value="&lt;font color=&quot;#FFFFFF&quot; style=&quot;font-family:Consolas;&quot;&gt;&lt;b&gt;TCP port 8000&lt;/b&gt;&lt;br&gt;FastAPI app server&lt;br&gt;docker -p 8000:8000&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2E7D32;strokeColor=#1B5E20;strokeWidth=1;" vertex="1" parent="1">
          <mxGeometry x="1660" y="940" width="200" height="70" as="geometry" />
        </mxCell>
        <mxCell id="l4https" value="&lt;font color=&quot;#FFFFFF&quot; style=&quot;font-family:Consolas;&quot;&gt;&lt;b&gt;TCP port 443&lt;/b&gt;&lt;br&gt;HTTPS — Terraform → OCI API&lt;br&gt;docker push → OCIR&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2E7D32;strokeColor=#1B5E20;strokeWidth=1;" vertex="1" parent="1">
          <mxGeometry x="1880" y="940" width="200" height="70" as="geometry" />
        </mxCell>
        <mxCell id="l4firewall" value="&lt;font color=&quot;#FFD700&quot; style=&quot;font-family:Consolas;font-size:12px;&quot;&gt;&lt;b&gt;firewalld operates HERE&lt;/b&gt; — allows/blocks by TCP port&lt;br&gt;On OCI compute instances: firewall-cmd --add-port=8000/tcp&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1a2e1a;strokeColor=#FFD700;strokeWidth=1;" vertex="1" parent="1">
          <mxGeometry x="1440" y="1025" width="540" height="50" as="geometry" />
        </mxCell>

        <!-- ==================== -->
        <!-- OSI Layer 3 — Network -->
        <!-- ==================== -->
        <mxCell id="osiL3Group" value="&lt;font style=&quot;font-size:15px;color:#FFFFFF;&quot;&gt;&lt;b&gt;Layer 3 — NETWORK&lt;/b&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0096D6;strokeColor=#0077AA;strokeWidth=3;verticalAlign=top;spacingTop=5;arcSize=8;opacity=90;" vertex="1" parent="1">
          <mxGeometry x="1420" y="1130" width="680" height="350" as="geometry" />
        </mxCell>
        <mxCell id="l3ips" value="&lt;font color=&quot;#FFFFFF&quot; style=&quot;font-family:Consolas;&quot;&gt;&lt;b&gt;IP Addresses:&lt;/b&gt;&lt;br&gt;Bastion (public):  203.0.113.50&lt;br&gt;App server (private): 10.0.2.99&lt;br&gt;Your home IP: assigned by ISP&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#006699;strokeColor=#005588;strokeWidth=1;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="1440" y="1180" width="310" height="85" as="geometry" />
        </mxCell>
        <mxCell id="l3vcn" value="&lt;font color=&quot;#FFFFFF&quot; style=&quot;font-family:Consolas;&quot;&gt;&lt;b&gt;VCN Routing:&lt;/b&gt;&lt;br&gt;Public subnet → Internet Gateway&lt;br&gt;Private subnet → NAT Gateway&lt;br&gt;Route tables configured by Terraform&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#006699;strokeColor=#005588;strokeWidth=1;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="1770" y="1180" width="310" height="85" as="geometry" />
        </mxCell>
        <mxCell id="l3seclist" value="&lt;font color=&quot;#FFFFFF&quot; style=&quot;font-family:Consolas;&quot;&gt;&lt;b&gt;Security Lists:&lt;/b&gt; Terraform configures these&lt;br&gt;Source IP + port filtering (stateful rules)&lt;br&gt;Ingress: allow SSH from your IP only&lt;br&gt;Egress: allow all outbound&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#006699;strokeColor=#005588;strokeWidth=1;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="1440" y="1280" width="400" height="80" as="geometry" />
        </mxCell>
        <mxCell id="l3route" value="&lt;font color=&quot;#FFFFFF&quot; style=&quot;font-family:Consolas;&quot;&gt;&lt;b&gt;Your ISP assigns your home IP&lt;/b&gt;&lt;br&gt;→ routes to OCI data center&lt;br&gt;(Ashburn, VA — us-ashburn-1)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#006699;strokeColor=#005588;strokeWidth=1;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="1440" y="1375" width="350" height="65" as="geometry" />
        </mxCell>

        <!-- ==================== -->
        <!-- OSI Layer 2 — Data Link -->
        <!-- ==================== -->
        <mxCell id="osiL2Group" value="&lt;font style=&quot;font-size:15px;color:#FFFFFF;&quot;&gt;&lt;b&gt;Layer 2 — DATA LINK&lt;/b&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#9C27B0;strokeColor=#7B1FA2;strokeWidth=3;verticalAlign=top;spacingTop=5;arcSize=8;opacity=90;" vertex="1" parent="1">
          <mxGeometry x="1420" y="1500" width="680" height="170" as="geometry" />
        </mxCell>
        <mxCell id="l2ethernet" value="&lt;font color=&quot;#FFFFFF&quot; style=&quot;font-family:Consolas;&quot;&gt;&lt;b&gt;Ethernet Frames&lt;/b&gt;&lt;br&gt;On your local network (LAN)&lt;br&gt;Encapsulate IP packets for local delivery&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#7B1FA2;strokeColor=#6A1B9A;strokeWidth=1;" vertex="1" parent="1">
          <mxGeometry x="1440" y="1550" width="280" height="65" as="geometry" />
        </mxCell>
        <mxCell id="l2mac" value="&lt;font color=&quot;#FFFFFF&quot; style=&quot;font-family:Consolas;&quot;&gt;&lt;b&gt;MAC Addresses&lt;/b&gt;&lt;br&gt;Your NIC, your router&lt;br&gt;ARP resolves IP → MAC&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#7B1FA2;strokeColor=#6A1B9A;strokeWidth=1;" vertex="1" parent="1">
          <mxGeometry x="1740" y="1550" width="200" height="65" as="geometry" />
        </mxCell>
        <mxCell id="l2vnic" value="&lt;font color=&quot;#FFFFFF&quot; style=&quot;font-family:Consolas;&quot;&gt;&lt;b&gt;VNICs&lt;/b&gt; on OCI&lt;br&gt;instances&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#7B1FA2;strokeColor=#6A1B9A;strokeWidth=1;" vertex="1" parent="1">
          <mxGeometry x="1960" y="1550" width="120" height="65" as="geometry" />
        </mxCell>

        <!-- ==================== -->
        <!-- OSI Layer 1 — Physical -->
        <!-- ==================== -->
        <mxCell id="osiL1Group" value="&lt;font style=&quot;font-size:15px;color:#FFFFFF;&quot;&gt;&lt;b&gt;Layer 1 — PHYSICAL&lt;/b&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#606060;strokeColor=#888888;strokeWidth=3;verticalAlign=top;spacingTop=5;arcSize=8;opacity=90;" vertex="1" parent="1">
          <mxGeometry x="1420" y="1690" width="680" height="140" as="geometry" />
        </mxCell>
        <mxCell id="l1path" value="&lt;font color=&quot;#FFFFFF&quot; style=&quot;font-family:Consolas;font-size:12px;&quot;&gt;&lt;b&gt;Physical path:&lt;/b&gt;&lt;br&gt;Your WiFi/Ethernet → Router → ISP → Internet backbone → OCI Data Center (Ashburn, VA)&lt;br&gt;Fiber optic cables, switches, routers along the way&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#4a4a4a;strokeColor=#777777;strokeWidth=1;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="1440" y="1740" width="640" height="70" as="geometry" />
        </mxCell>

        <!-- ============================================================ -->
        <!-- TOOL-TO-OSI MAPPING (right side, below OSI stack) -->
        <!-- ============================================================ -->
        <mxCell id="mappingHeader" value="&lt;font style=&quot;font-size:17px;color:#FFFFFF;&quot;&gt;&lt;b&gt;TOOL → OSI LAYER MAPPING&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=0;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="1420" y="1860" width="680" height="35" as="geometry" />
        </mxCell>

        <mxCell id="mappingBox" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2a2a3e;strokeColor=#555577;strokeWidth=2;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="1420" y="1900" width="680" height="380" as="geometry" />
        </mxCell>

        <mxCell id="map1" value="&lt;font color=&quot;#E84D4D&quot; style=&quot;font-family:Consolas;font-size:13px;&quot;&gt;&lt;b&gt;Terraform&lt;/b&gt;&lt;/font&gt;&lt;font color=&quot;#AAAAAA&quot; style=&quot;font-size:13px;&quot;&gt;  →  &lt;/font&gt;&lt;font color=&quot;#0096D6&quot; style=&quot;font-size:13px;&quot;&gt;&lt;b&gt;L3&lt;/b&gt; (creates networks, routes, security lists)&lt;/font&gt;&lt;font color=&quot;#AAAAAA&quot; style=&quot;font-size:13px;&quot;&gt; + &lt;/font&gt;&lt;font color=&quot;#E84D4D&quot; style=&quot;font-size:13px;&quot;&gt;&lt;b&gt;L7&lt;/b&gt; (API calls to OCI)&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=0;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="1440" y="1915" width="640" height="30" as="geometry" />
        </mxCell>
        <mxCell id="map2" value="&lt;font color=&quot;#E84D4D&quot; style=&quot;font-family:Consolas;font-size:13px;&quot;&gt;&lt;b&gt;Ansible&lt;/b&gt;&lt;/font&gt;&lt;font color=&quot;#AAAAAA&quot; style=&quot;font-size:13px;&quot;&gt;    →  &lt;/font&gt;&lt;font color=&quot;#E84D4D&quot; style=&quot;font-size:13px;&quot;&gt;&lt;b&gt;L7&lt;/b&gt; (runs tasks on servers)&lt;/font&gt;&lt;font color=&quot;#AAAAAA&quot; style=&quot;font-size:13px;&quot;&gt; + &lt;/font&gt;&lt;font color=&quot;#FFC107&quot; style=&quot;font-size:13px;&quot;&gt;&lt;b&gt;L5&lt;/b&gt; (SSH session management)&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=0;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="1440" y="1950" width="640" height="30" as="geometry" />
        </mxCell>
        <mxCell id="map3" value="&lt;font color=&quot;#E84D4D&quot; style=&quot;font-family:Consolas;font-size:13px;&quot;&gt;&lt;b&gt;Docker&lt;/b&gt;&lt;/font&gt;&lt;font color=&quot;#AAAAAA&quot; style=&quot;font-size:13px;&quot;&gt;     →  &lt;/font&gt;&lt;font color=&quot;#E84D4D&quot; style=&quot;font-size:13px;&quot;&gt;&lt;b&gt;L7&lt;/b&gt; (build/run commands)&lt;/font&gt;&lt;font color=&quot;#AAAAAA&quot; style=&quot;font-size:13px;&quot;&gt; + &lt;/font&gt;&lt;font color=&quot;#4CAF50&quot; style=&quot;font-size:13px;&quot;&gt;&lt;b&gt;L4&lt;/b&gt; (port mapping -p 8000:8000)&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=0;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="1440" y="1985" width="640" height="30" as="geometry" />
        </mxCell>
        <mxCell id="map4" value="&lt;font color=&quot;#E84D4D&quot; style=&quot;font-family:Consolas;font-size:13px;&quot;&gt;&lt;b&gt;curl&lt;/b&gt;&lt;/font&gt;&lt;font color=&quot;#AAAAAA&quot; style=&quot;font-size:13px;&quot;&gt;       →  &lt;/font&gt;&lt;font color=&quot;#E84D4D&quot; style=&quot;font-size:13px;&quot;&gt;&lt;b&gt;L7&lt;/b&gt; (HTTP request/response)&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=0;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="1440" y="2020" width="640" height="30" as="geometry" />
        </mxCell>
        <mxCell id="map5" value="&lt;font color=&quot;#4CAF50&quot; style=&quot;font-family:Consolas;font-size:13px;&quot;&gt;&lt;b&gt;firewalld&lt;/b&gt;&lt;/font&gt;&lt;font color=&quot;#AAAAAA&quot; style=&quot;font-size:13px;&quot;&gt;  →  &lt;/font&gt;&lt;font color=&quot;#0096D6&quot; style=&quot;font-size:13px;&quot;&gt;&lt;b&gt;L3&lt;/b&gt;&lt;/font&gt;&lt;font color=&quot;#AAAAAA&quot; style=&quot;font-size:13px;&quot;&gt; / &lt;/font&gt;&lt;font color=&quot;#4CAF50&quot; style=&quot;font-size:13px;&quot;&gt;&lt;b&gt;L4&lt;/b&gt; (IP + port filtering)&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=0;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="1440" y="2055" width="640" height="30" as="geometry" />
        </mxCell>
        <mxCell id="map6" value="&lt;font color=&quot;#FF8C00&quot; style=&quot;font-family:Consolas;font-size:13px;&quot;&gt;&lt;b&gt;SSH&lt;/b&gt;&lt;/font&gt;&lt;font color=&quot;#AAAAAA&quot; style=&quot;font-size:13px;&quot;&gt;        →  &lt;/font&gt;&lt;font color=&quot;#FFC107&quot; style=&quot;font-size:13px;&quot;&gt;&lt;b&gt;L5&lt;/b&gt; (session)&lt;/font&gt;&lt;font color=&quot;#AAAAAA&quot; style=&quot;font-size:13px;&quot;&gt; + &lt;/font&gt;&lt;font color=&quot;#FF8C00&quot; style=&quot;font-size:13px;&quot;&gt;&lt;b&gt;L6&lt;/b&gt; (encryption)&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=0;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="1440" y="2090" width="640" height="30" as="geometry" />
        </mxCell>
        <mxCell id="map7" value="&lt;font color=&quot;#0096D6&quot; style=&quot;font-family:Consolas;font-size:13px;&quot;&gt;&lt;b&gt;VCN/Subnets&lt;/b&gt;&lt;/font&gt;&lt;font color=&quot;#AAAAAA&quot; style=&quot;font-size:13px;&quot;&gt;  →  &lt;/font&gt;&lt;font color=&quot;#0096D6&quot; style=&quot;font-size:13px;&quot;&gt;&lt;b&gt;L3&lt;/b&gt; (IP routing between subnets)&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=0;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="1440" y="2125" width="640" height="30" as="geometry" />
        </mxCell>
        <mxCell id="map8" value="&lt;font color=&quot;#0096D6&quot; style=&quot;font-family:Consolas;font-size:13px;&quot;&gt;&lt;b&gt;Security Lists&lt;/b&gt;&lt;/font&gt;&lt;font color=&quot;#AAAAAA&quot; style=&quot;font-size:13px;&quot;&gt;  →  &lt;/font&gt;&lt;font color=&quot;#0096D6&quot; style=&quot;font-size:13px;&quot;&gt;&lt;b&gt;L3&lt;/b&gt;&lt;/font&gt;&lt;font color=&quot;#AAAAAA&quot; style=&quot;font-size:13px;&quot;&gt; / &lt;/font&gt;&lt;font color=&quot;#4CAF50&quot; style=&quot;font-size:13px;&quot;&gt;&lt;b&gt;L4&lt;/b&gt; (source IP + port rules)&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=0;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="1440" y="2160" width="640" height="30" as="geometry" />
        </mxCell>

        <!-- Colored dots legend -->
        <mxCell id="legendNote" value="&lt;font color=&quot;#888888&quot; style=&quot;font-size:11px;&quot;&gt;Colors match OSI layer: &lt;font color=&quot;#E84D4D&quot;&gt;L7&lt;/font&gt; &lt;font color=&quot;#FF8C00&quot;&gt;L6&lt;/font&gt; &lt;font color=&quot;#FFC107&quot;&gt;L5&lt;/font&gt; &lt;font color=&quot;#4CAF50&quot;&gt;L4&lt;/font&gt; &lt;font color=&quot;#0096D6&quot;&gt;L3&lt;/font&gt; &lt;font color=&quot;#9C27B0&quot;&gt;L2&lt;/font&gt; &lt;font color=&quot;#606060&quot;&gt;L1&lt;/font&gt;&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=0;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="1440" y="2200" width="500" height="25" as="geometry" />
        </mxCell>

        <!-- ============================================================ -->
        <!-- DATA FLOW TRACE -->
        <!-- ============================================================ -->
        <mxCell id="flowHeader" value="&lt;font style=&quot;font-size:17px;color:#FFFFFF;&quot;&gt;&lt;b&gt;DATA FLOW TRACE: &quot;What happens when Ansible runs a playbook?&quot;&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=0;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="1420" y="2310" width="680" height="35" as="geometry" />
        </mxCell>

        <mxCell id="flowBox" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1e1e3a;strokeColor=#FFD700;strokeWidth=2;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="1420" y="2350" width="680" height="500" as="geometry" />
        </mxCell>

        <!-- Flow steps -->
        <mxCell id="flow1" value="&lt;font style=&quot;font-size:13px;&quot;&gt;&lt;font color=&quot;#E84D4D&quot;&gt;&lt;b&gt;1. L7 Application&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#CCCCCC&quot;&gt;Ansible reads inventory file, builds SSH command&lt;br&gt;&lt;font style=&quot;font-family:Consolas;&quot;&gt;ansible-playbook -i inventory deploy_app.yml&lt;/font&gt;&lt;/font&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#3a1a1a;strokeColor=#E84D4D;strokeWidth=1;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="1440" y="2365" width="640" height="55" as="geometry" />
        </mxCell>

        <mxCell id="flow2" value="&lt;font style=&quot;font-size:13px;&quot;&gt;&lt;font color=&quot;#FFC107&quot;&gt;&lt;b&gt;2. L5 Session&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#CCCCCC&quot;&gt;Opens SSH session to bastion via &lt;font style=&quot;font-family:Consolas;&quot;&gt;ProxyCommand&lt;/font&gt;&lt;/font&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2e2e1a;strokeColor=#FFC107;strokeWidth=1;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="1440" y="2427" width="640" height="45" as="geometry" />
        </mxCell>

        <mxCell id="flow3" value="&lt;font style=&quot;font-size:13px;&quot;&gt;&lt;font color=&quot;#FF8C00&quot;&gt;&lt;b&gt;3. L6 Presentation&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#CCCCCC&quot;&gt;SSH encrypts the connection (Ed25519/RSA key exchange)&lt;/font&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2e1e0a;strokeColor=#FF8C00;strokeWidth=1;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="1440" y="2479" width="640" height="45" as="geometry" />
        </mxCell>

        <mxCell id="flow4" value="&lt;font style=&quot;font-size:13px;&quot;&gt;&lt;font color=&quot;#4CAF50&quot;&gt;&lt;b&gt;4. L4 Transport&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#CCCCCC&quot;&gt;TCP connection established to &lt;font style=&quot;font-family:Consolas;&quot;&gt;bastion:22&lt;/font&gt; (3-way handshake)&lt;/font&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1a2e1a;strokeColor=#4CAF50;strokeWidth=1;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="1440" y="2531" width="640" height="45" as="geometry" />
        </mxCell>

        <mxCell id="flow5" value="&lt;font style=&quot;font-size:13px;&quot;&gt;&lt;font color=&quot;#0096D6&quot;&gt;&lt;b&gt;5. L3 Network&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#CCCCCC&quot;&gt;Packet routed: &lt;font style=&quot;font-family:Consolas;&quot;&gt;your IP → ISP → internet → OCI IGW → bastion (203.0.113.50)&lt;/font&gt;&lt;/font&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0a1e2e;strokeColor=#0096D6;strokeWidth=1;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="1440" y="2583" width="640" height="45" as="geometry" />
        </mxCell>

        <mxCell id="flow6" value="&lt;font style=&quot;font-size:13px;&quot;&gt;&lt;font color=&quot;#FFC107&quot;&gt;&lt;b&gt;6. L5 Session (hop 2)&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#CCCCCC&quot;&gt;SSH jumps: bastion opens second SSH session to &lt;font style=&quot;font-family:Consolas;&quot;&gt;app-server:22&lt;/font&gt;&lt;/font&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2e2e1a;strokeColor=#FFC107;strokeWidth=1;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="1440" y="2635" width="640" height="45" as="geometry" />
        </mxCell>

        <mxCell id="flow7" value="&lt;font style=&quot;font-size:13px;&quot;&gt;&lt;font color=&quot;#0096D6&quot;&gt;&lt;b&gt;7. L3 Network (internal)&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#CCCCCC&quot;&gt;Packet routed: &lt;font style=&quot;font-family:Consolas;&quot;&gt;bastion (10.0.1.x) → app-server (10.0.2.x)&lt;/font&gt; via VCN routing&lt;/font&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0a1e2e;strokeColor=#0096D6;strokeWidth=1;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="1440" y="2687" width="640" height="45" as="geometry" />
        </mxCell>

        <mxCell id="flow8" value="&lt;font style=&quot;font-size:13px;&quot;&gt;&lt;font color=&quot;#E84D4D&quot;&gt;&lt;b&gt;8. L7 Application (remote)&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#CCCCCC&quot;&gt;Ansible runs task on app server: &lt;font style=&quot;font-family:Consolas;&quot;&gt;dnf install python3&lt;/font&gt;&lt;/font&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#3a1a1a;strokeColor=#E84D4D;strokeWidth=1;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="1440" y="2739" width="640" height="45" as="geometry" />
        </mxCell>

        <!-- Flow arrows (vertical connecting line) -->
        <mxCell id="flowArrow1" value="" style="endArrow=block;endFill=1;strokeColor=#FFD700;strokeWidth=2;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1435" y="2395" as="sourcePoint" />
            <mxPoint x="1435" y="2775" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="flowArrowLabel" value="&lt;font color=&quot;#FFD700&quot; style=&quot;font-size:11px;&quot;&gt;packet&lt;br&gt;flow&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=0;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="1400" y="2570" width="35" height="35" as="geometry" />
        </mxCell>

        <!-- Return path note -->
        <mxCell id="flowReturn" value="&lt;font color=&quot;#FFD700&quot; style=&quot;font-size:12px;&quot;&gt;&lt;b&gt;Return path:&lt;/b&gt; Response travels back up through L3 → L4 → L5 → L6 → L7&lt;br&gt;Ansible collects output and reports &quot;changed&quot; or &quot;ok&quot; in the terminal&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2e2e1a;strokeColor=#FFD700;strokeWidth=1;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="1440" y="2800" width="640" height="40" as="geometry" />
        </mxCell>

        <!-- ============================================================ -->
        <!-- CONNECTING ARROWS between left and right halves -->
        <!-- ============================================================ -->

        <!-- Terraform arrow to L3/L7 -->
        <mxCell id="toolArrowTF" value="" style="endArrow=block;endFill=1;strokeColor=#E84D4D;strokeWidth=1;dashed=1;dashPattern=4 4;exitX=1;exitY=0.5;exitDx=0;exitDy=0;" edge="1" parent="1" source="toolTerraform">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1420" y="400" as="targetPoint" />
            <Array as="points">
              <mxPoint x="1350" y="2818" />
              <mxPoint x="1350" y="400" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Ansible arrow to L7/L5 -->
        <mxCell id="toolArrowAnsible" value="" style="endArrow=block;endFill=1;strokeColor=#4CAF50;strokeWidth=1;dashed=1;dashPattern=4 4;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="200" y="1075" as="sourcePoint" />
            <mxPoint x="1420" y="270" as="targetPoint" />
            <Array as="points">
              <mxPoint x="200" y="860" />
              <mxPoint x="680" y="860" />
              <mxPoint x="680" y="270" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- ============================================================ -->
        <!-- FOOTER / LEGEND -->
        <!-- ============================================================ -->
        <mxCell id="footer" value="&lt;font style=&quot;font-size:12px;color:#666666;&quot;&gt;OCI Federal Lab — Local Development Environment Architecture | Created for interview preparation and learning reference&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=0;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="400" y="3870" width="2000" height="25" as="geometry" />
        </mxCell>

