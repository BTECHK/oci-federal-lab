        <mxCell id="leg4t" value="&lt;font color=&quot;#CCCCCC&quot; style=&quot;font-size:12px;&quot;&gt;WSL2 / Transport L4&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=0;strokeColor=none;fillColor=none;" vertex="1" parent="1">
