        <mxCell id="leg3t" value="&lt;font color=&quot;#CCCCCC&quot; style=&quot;font-size:12px;&quot;&gt;Hyper-V / Presentation L6&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=0;strokeColor=none;fillColor=none;" vertex="1" parent="1">
