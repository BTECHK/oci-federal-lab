        <!-- ===== File Tree Block ===== -->
        <mxCell id="s0_tree" value="&lt;font face=&quot;Consolas&quot; style=&quot;font-size:11px;&quot;&gt;&lt;font color=&quot;#CCCCCC&quot;&gt;phases/phase-1-fedtracker-migration/&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#CCCCCC&quot;&gt;├── &lt;/font&gt;&lt;font color=&quot;#0096D6&quot;&gt;&lt;b&gt;terraform/&lt;/b&gt;&lt;/font&gt;&lt;font color=&quot;#555555&quot;&gt; ··············· &lt;/font&gt;&lt;font color=&quot;#0096D6&quot;&gt;BLUE — feeds Section 1&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#CCCCCC&quot;&gt;│   ├── provider.tf&lt;/font&gt;&lt;font color=&quot;#666666&quot;&gt;       ← OCI auth config (API key)&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#CCCCCC&quot;&gt;│   ├── variables.tf&lt;/font&gt;&lt;font color=&quot;#666666&quot;&gt;      ← input definitions (region, shape, CIDR)&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#CCCCCC&quot;&gt;│   ├── terraform.tfvars&lt;/font&gt;&lt;font color=&quot;#FF5722&quot;&gt;  ← actual secret values (gitignored!)&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#CCCCCC&quot;&gt;│   ├── network.tf&lt;/font&gt;&lt;font color=&quot;#666666&quot;&gt;        ← VCN, subnets, gateways, routes&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#CCCCCC&quot;&gt;│   ├── compute.tf&lt;/font&gt;&lt;font color=&quot;#666666&quot;&gt;        ← bastion + app server VMs&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#CCCCCC&quot;&gt;│   └── outputs.tf&lt;/font&gt;&lt;font color=&quot;#666666&quot;&gt;        ← exports bastion_public_ip, app_server_private_ip&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#CCCCCC&quot;&gt;├── &lt;/font&gt;&lt;font color=&quot;#4CAF50&quot;&gt;&lt;b&gt;ansible/&lt;/b&gt;&lt;/font&gt;&lt;font color=&quot;#555555&quot;&gt; ················· &lt;/font&gt;&lt;font color=&quot;#4CAF50&quot;&gt;GREEN — feeds Section 3&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#CCCCCC&quot;&gt;│   ├── inventory/&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#CCCCCC&quot;&gt;│   │   └── inventory.ini&lt;/font&gt;&lt;font color=&quot;#666666&quot;&gt; ← target hosts + SSH ProxyCommand config&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#CCCCCC&quot;&gt;│   ├── playbooks/&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#CCCCCC&quot;&gt;│   │   ├── harden.yml&lt;/font&gt;&lt;font color=&quot;#666666&quot;&gt;   ← 20 security tasks (SSH, firewall, audit, PAM)&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#CCCCCC&quot;&gt;│   │   └── deploy_app.yml&lt;/font&gt;&lt;font color=&quot;#666666&quot;&gt;← install deps, copy app, create systemd service&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#CCCCCC&quot;&gt;│   └── templates/&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#CCCCCC&quot;&gt;│       └── fedtracker.service.j2&lt;/font&gt;&lt;font color=&quot;#666666&quot;&gt; ← Jinja2 template for systemd unit&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#CCCCCC&quot;&gt;├── &lt;/font&gt;&lt;font color=&quot;#00B4AA&quot;&gt;&lt;b&gt;docker/&lt;/b&gt;&lt;/font&gt;&lt;font color=&quot;#555555&quot;&gt; ·················· &lt;/font&gt;&lt;font color=&quot;#00B4AA&quot;&gt;TEAL — feeds Section 4&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#CCCCCC&quot;&gt;│   └── Dockerfile&lt;/font&gt;&lt;font color=&quot;#666666&quot;&gt;        ← OL9-slim, Python 3.11, non-root user&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#CCCCCC&quot;&gt;├── &lt;/font&gt;&lt;font color=&quot;#FFFFFF&quot;&gt;&lt;b&gt;app/&lt;/b&gt;&lt;/font&gt;&lt;font color=&quot;#555555&quot;&gt; ····················· &lt;/font&gt;&lt;font color=&quot;#AAAAAA&quot;&gt;SHARED — used by both Ansible + Docker&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#CCCCCC&quot;&gt;│   ├── main.py&lt;/font&gt;&lt;font color=&quot;#666666&quot;&gt;           ← FastAPI application (the thing being deployed)&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#CCCCCC&quot;&gt;│   └── requirements.txt&lt;/font&gt;&lt;font color=&quot;#666666&quot;&gt;  ← pip dependencies (fastapi, uvicorn, oracledb)&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#CCCCCC&quot;&gt;└── &lt;/font&gt;&lt;font color=&quot;#888888&quot;&gt;&lt;b&gt;docs/&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#CCCCCC&quot;&gt;    └── implementation-guide.md&lt;/font&gt;&lt;font color=&quot;#666666&quot;&gt; ← 8300-line step-by-step guide&lt;/font&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0d0d1e;strokeColor=#444444;strokeWidth=1;fontColor=#e0e0e0;arcSize=6;verticalAlign=top;spacingTop=8;spacingLeft=12;spacingRight=12;align=left;fontSize=12;" vertex="1" parent="1">
