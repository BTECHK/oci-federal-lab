        <mxCell id="legend_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1a1a2e;strokeColor=#444444;strokeWidth=1;arcSize=4;" vertex="1" parent="1">
          <mxGeometry x="1650" y="3420" width="560" height="120" as="geometry" />
        </mxCell>

        <mxCell id="legend_title" value="&lt;font style=&quot;font-size:13px;&quot; color=&quot;#999999&quot;&gt;&lt;b&gt;LEGEND&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="1665" y="3428" width="70" height="26" as="geometry" />
        </mxCell>

        <mxCell id="legend_blue" value="&lt;font color=&quot;#0096D6&quot;&gt;&#9632;&lt;/font&gt; Terraform" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontColor=#b0b0b0;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1665" y="3454" width="100" height="26" as="geometry" />
