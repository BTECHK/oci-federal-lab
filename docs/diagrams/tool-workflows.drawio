        </mxCell>

        <!-- Rebuild pipeline label -->
        <mxCell id="s5_rebuild_label" value="&lt;font color=&quot;#81C784&quot; style=&quot;font-size:11px;&quot;&gt;Full destroy-and-rebuild proves infrastructure is truly repeatable &amp;mdash; nothing was &quot;hand-configured&quot;&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontFamily=Consolas;" vertex="1" parent="1">
          <mxGeometry x="70" y="2840" width="750" height="26" as="geometry" />
        </mxCell>

        <!-- Big arrow connecting Phase A to Phase B -->
        <mxCell id="s5_phase_arrow" value="&lt;font style=&quot;font-size:12px;&quot; color=&quot;#FFC107&quot;&gt;&lt;b&gt;CLEAN SLATE&lt;br&gt;(0 resources)&lt;/b&gt;&lt;/font&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#FFC107;strokeWidth=3;dashed=1;dashPattern=8 4;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="s5d_vcn" target="s5r_apply" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1190" y="2670" />
              <mxPoint x="50" y="2670" />
              <mxPoint x="50" y="2770" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- ============================================================ -->
        <!-- SECTION 6: THE HANDOFF — Yellow theme                        -->
        <!-- ============================================================ -->

        <!-- Section 6 Container -->
        <mxCell id="s6_container" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2e2a0a;strokeColor=#FFC107;strokeWidth=2;arcSize=4;" vertex="1" parent="1">
          <mxGeometry x="40" y="3020" width="2320" height="520" as="geometry" />
        </mxCell>

        <!-- Section 6 Title -->
        <mxCell id="s6_title" value="&lt;font style=&quot;font-size:18px;&quot;&gt;&lt;b&gt;SECTION 6: THE HANDOFF &amp;mdash; Terraform Output &amp;rarr; Ansible Inventory&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontColor=#FFC107;fontFamily=Consolas;" vertex="1" parent="1">
          <mxGeometry x="60" y="3030" width="740" height="30" as="geometry" />
        </mxCell>

        <!-- Terraform output box -->
        <mxCell id="s6_tf_output" value="&lt;font face=&quot;Consolas&quot;&gt;&lt;b&gt;terraform output&lt;/b&gt;&lt;/font&gt;&lt;hr size=&quot;1&quot; style=&quot;border-color:#0096D6;&quot;&gt;&lt;font face=&quot;Consolas&quot; style=&quot;font-size:11px;&quot;&gt;bastion_public_ip = &quot;129.153.x.x&quot;&lt;br&gt;app_server_private_ip = &quot;10.0.1.x&quot;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0d2137;strokeColor=#0096D6;strokeWidth=2;fontColor=#e0e0e0;arcSize=8;verticalAlign=top;spacingTop=4;spacingLeft=8;spacingRight=8;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="70" y="3090" width="360" height="100" as="geometry" />
        </mxCell>

        <!-- Variable capture box -->
        <mxCell id="s6_capture" value="&lt;b&gt;Capture into shell variables&lt;/b&gt;&lt;hr size=&quot;1&quot; style=&quot;border-color:#FFC107;&quot;&gt;&lt;font face=&quot;Consolas&quot; style=&quot;font-size:11px;&quot;&gt;BASTION_IP=$(terraform output \&lt;br&gt;&amp;nbsp;&amp;nbsp;-raw bastion_public_ip)&lt;br&gt;&lt;br&gt;APP_IP=$(terraform output \&lt;br&gt;&amp;nbsp;&amp;nbsp;-raw app_server_private_ip)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2e2a0a;strokeColor=#FFC107;strokeWidth=2;fontColor=#e0e0e0;arcSize=8;verticalAlign=top;spacingTop=4;spacingLeft=8;spacingRight=8;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="70" y="3230" width="360" height="140" as="geometry" />
        </mxCell>

        <!-- Arrow: output → capture -->
        <mxCell id="s6_arrow_cap" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#FFC107;strokeWidth=2;" edge="1" source="s6_tf_output" target="s6_capture" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- sed #1 box -->
        <mxCell id="s6_sed1" value="&lt;font face=&quot;Consolas&quot; style=&quot;font-size:12px;&quot; color=&quot;#FFC107&quot;&gt;&lt;b&gt;sed #1&lt;/b&gt;&lt;/font&gt;&lt;hr size=&quot;1&quot; style=&quot;border-color:#FFC107;&quot;&gt;&lt;font face=&quot;Consolas&quot; style=&quot;font-size:10px;&quot;&gt;sed -i &quot;s/bastion_server \&lt;br&gt;&amp;nbsp;&amp;nbsp;ansible_host=.*/bastion_server \&lt;br&gt;&amp;nbsp;&amp;nbsp;ansible_host=$BASTION_IP/&quot; \&lt;br&gt;&amp;nbsp;&amp;nbsp;inventory.ini&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px;&quot;&gt;Updates bastion public IP&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2e2a0a;strokeColor=#FFC107;strokeWidth=2;fontColor=#e0e0e0;arcSize=8;verticalAlign=top;spacingTop=4;spacingLeft=6;spacingRight=6;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="520" y="3080" width="350" height="150" as="geometry" />
        </mxCell>

        <!-- sed #2 box -->
        <mxCell id="s6_sed2" value="&lt;font face=&quot;Consolas&quot; style=&quot;font-size:12px;&quot; color=&quot;#FFC107&quot;&gt;&lt;b&gt;sed #2&lt;/b&gt;&lt;/font&gt;&lt;hr size=&quot;1&quot; style=&quot;border-color:#FFC107;&quot;&gt;&lt;font face=&quot;Consolas&quot; style=&quot;font-size:10px;&quot;&gt;sed -i &quot;s/app-server \&lt;br&gt;&amp;nbsp;&amp;nbsp;ansible_host=.*/app-server \&lt;br&gt;&amp;nbsp;&amp;nbsp;ansible_host=$APP_IP/&quot; \&lt;br&gt;&amp;nbsp;&amp;nbsp;inventory.ini&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px;&quot;&gt;Updates app private IP&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2e2a0a;strokeColor=#FFC107;strokeWidth=2;fontColor=#e0e0e0;arcSize=8;verticalAlign=top;spacingTop=4;spacingLeft=6;spacingRight=6;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="520" y="3250" width="350" height="150" as="geometry" />
        </mxCell>

        <!-- sed #3 box -->
        <mxCell id="s6_sed3" value="&lt;font face=&quot;Consolas&quot; style=&quot;font-size:12px;&quot; color=&quot;#FFC107&quot;&gt;&lt;b&gt;sed #3&lt;/b&gt;&lt;/font&gt;&lt;hr size=&quot;1&quot; style=&quot;border-color:#FFC107;&quot;&gt;&lt;font face=&quot;Consolas&quot; style=&quot;font-size:10px;&quot;&gt;sed -i &quot;s/opc@[0-9.]*/\&lt;br&gt;&amp;nbsp;&amp;nbsp;opc@$BASTION_IP/&quot; \&lt;br&gt;&amp;nbsp;&amp;nbsp;inventory.ini&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px;&quot;&gt;Updates ProxyCommand bastion IP&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2e2a0a;strokeColor=#FFC107;strokeWidth=2;fontColor=#e0e0e0;arcSize=8;verticalAlign=top;spacingTop=4;spacingLeft=6;spacingRight=6;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="520" y="3420" width="350" height="120" as="geometry" />
        </mxCell>

        <!-- Arrows: capture → sed boxes -->
        <mxCell id="s6_arr_sed1" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#FFC107;strokeWidth=2;exitX=1;exitY=0.25;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="s6_capture" target="s6_sed1" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="s6_arr_sed2" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#FFC107;strokeWidth=2;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="s6_capture" target="s6_sed2" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="s6_arr_sed3" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#FFC107;strokeWidth=2;exitX=1;exitY=0.75;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="s6_capture" target="s6_sed3" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Updated inventory.ini result -->
        <mxCell id="s6_updated_inv" value="&lt;font face=&quot;Consolas&quot; color=&quot;#4CAF50&quot;&gt;&lt;b&gt;inventory.ini (updated)&lt;/b&gt;&lt;/font&gt;&lt;hr size=&quot;1&quot; style=&quot;border-color:#4CAF50;&quot;&gt;&lt;font face=&quot;Consolas&quot; style=&quot;font-size:10px;&quot;&gt;[bastion]&lt;br&gt;bastion_server ansible_host=&lt;b&gt;NEW_BASTION_IP&lt;/b&gt;&lt;br&gt;&lt;br&gt;[app]&lt;br&gt;app-server ansible_host=&lt;b&gt;NEW_APP_IP&lt;/b&gt;&lt;br&gt;&amp;nbsp;&amp;nbsp;ProxyCommand=&quot;ssh -W %h:%p&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;opc@&lt;b&gt;NEW_BASTION_IP&lt;/b&gt;&quot;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1b3a1b;strokeColor=#4CAF50;strokeWidth=2;fontColor=#e0e0e0;arcSize=8;verticalAlign=top;spacingTop=4;spacingLeft=8;spacingRight=8;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="960" y="3110" width="360" height="190" as="geometry" />
        </mxCell>

        <!-- Arrows: sed → updated inventory -->
        <mxCell id="s6_arr_inv1" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#FFC107;strokeWidth=2;entryX=0;entryY=0.25;entryDx=0;entryDy=0;" edge="1" source="s6_sed1" target="s6_updated_inv" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="s6_arr_inv2" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#FFC107;strokeWidth=2;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="s6_sed2" target="s6_updated_inv" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="s6_arr_inv3" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#FFC107;strokeWidth=2;entryX=0;entryY=0.75;entryDx=0;entryDy=0;" edge="1" source="s6_sed3" target="s6_updated_inv" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ansible-playbook reads updated inventory -->
        <mxCell id="s6_ansible_run" value="&lt;font face=&quot;Consolas&quot; color=&quot;#4CAF50&quot;&gt;&lt;b&gt;ansible-playbook&lt;/b&gt;&lt;/font&gt;&lt;hr size=&quot;1&quot; style=&quot;border-color:#4CAF50;&quot;&gt;&lt;font face=&quot;Consolas&quot; style=&quot;font-size:11px;&quot;&gt;ansible-playbook \&lt;br&gt;&amp;nbsp;&amp;nbsp;-i inventory.ini \&lt;br&gt;&amp;nbsp;&amp;nbsp;harden.yml&lt;br&gt;&lt;br&gt;ansible-playbook \&lt;br&gt;&amp;nbsp;&amp;nbsp;-i inventory.ini \&lt;br&gt;&amp;nbsp;&amp;nbsp;deploy_app.yml&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1b3a1b;strokeColor=#4CAF50;strokeWidth=2;fontColor=#e0e0e0;arcSize=8;verticalAlign=top;spacingTop=4;spacingLeft=8;spacingRight=8;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1410" y="3110" width="280" height="190" as="geometry" />
        </mxCell>

        <!-- Arrow: inventory → ansible -->
        <mxCell id="s6_arr_ansible" value="reads" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#4CAF50;strokeWidth=2;fontColor=#81C784;fontSize=11;fontFamily=Consolas;" edge="1" source="s6_updated_inv" target="s6_ansible_run" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Final success box -->
        <mxCell id="s6_success" value="&lt;font style=&quot;font-size:16px;&quot; color=&quot;#4CAF50&quot;&gt;&lt;b&gt;APP DEPLOYED&lt;/b&gt;&lt;/font&gt;&lt;hr size=&quot;1&quot; style=&quot;border-color:#4CAF50;&quot;&gt;&lt;font face=&quot;Consolas&quot; style=&quot;font-size:11px;&quot;&gt;FedTracker API running&lt;br&gt;Hardened OL8 server&lt;br&gt;Zero manual SSH config&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1b3a1b;strokeColor=#4CAF50;strokeWidth=3;fontColor=#e0e0e0;arcSize=8;verticalAlign=top;spacingTop=4;spacingLeft=8;spacingRight=8;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="1780" y="3125" width="250" height="130" as="geometry" />
        </mxCell>

        <!-- Arrow: ansible → success -->
        <mxCell id="s6_arr_success" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#4CAF50;strokeWidth=3;" edge="1" source="s6_ansible_run" target="s6_success" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Key insight label -->
        <mxCell id="s6_insight" value="&lt;font style=&quot;font-size:12px;&quot; color=&quot;#FFC107&quot;&gt;&lt;b&gt;KEY INSIGHT:&lt;/b&gt; The sed commands are the glue between Terraform (infrastructure) and Ansible (configuration).&lt;br&gt;Without this handoff, Ansible would target stale IPs from the previous deployment.&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="960" y="3340" width="730" height="46" as="geometry" />
        </mxCell>

