        <mxCell id="legend_project" value="&lt;font style=&quot;font-size:11px;&quot; color=&quot;#666666&quot;&gt;OCI Federal Lab &amp;mdash; Tool Workflow Architecture &amp;mdash; Phase 1, Days 1-4&lt;/font&gt;" style="text;html=1;align=right;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" vertex="1" parent="1">
