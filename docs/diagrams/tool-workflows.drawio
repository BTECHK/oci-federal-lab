        <mxCell id="legend_green" value="&lt;font color=&quot;#4CAF50&quot;&gt;&#9632;&lt;/font&gt; Ansible" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontColor=#b0b0b0;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1665" y="3480" width="80" height="26" as="geometry" />
