        <mxCell id="legend_red" value="&lt;font color=&quot;#FF5722&quot;&gt;&#9632;&lt;/font&gt; Destroy" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontColor=#b0b0b0;fontSize=11;" vertex="1" parent="1">
