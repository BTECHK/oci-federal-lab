        <!-- Arrow 3→4 -->
        <mxCell id="s1_arrow3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#0096D6;strokeWidth=2;fontColor=#b0b0b0;fontSize=11;fontFamily=Consolas;" edge="1" source="s1_plan" target="s1_apply" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Step 4: terraform apply -->
        <mxCell id="s1_apply" value="&lt;b&gt;&lt;font face=&quot;Consolas&quot;&gt;terraform apply&lt;/font&gt;&lt;/b&gt;&lt;hr size=&quot;1&quot; style=&quot;border-color:#0096D6;&quot;&gt;&lt;font style=&quot;font-size:11px;&quot;&gt;Creates resources in OCI via API&lt;br&gt;Prompts &lt;font face=&quot;Consolas&quot;&gt;yes&lt;/font&gt; to confirm&lt;br&gt;Builds in dependency order&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0d2137;strokeColor=#0096D6;strokeWidth=2;fontColor=#e0e0e0;arcSize=8;verticalAlign=top;spacingTop=4;spacingLeft=8;spacingRight=8;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="980" y="670" width="260" height="150" as="geometry" />
        </mxCell>

        <!-- Arrow 4→5 -->
        <mxCell id="s1_arrow4" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#0096D6;strokeWidth=2;fontColor=#b0b0b0;fontSize=11;fontFamily=Consolas;" edge="1" source="s1_apply" target="s1_output" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Step 5: terraform output -->
        <mxCell id="s1_output" value="&lt;b&gt;&lt;font face=&quot;Consolas&quot;&gt;terraform output&lt;/font&gt;&lt;/b&gt;&lt;hr size=&quot;1&quot; style=&quot;border-color:#0096D6;&quot;&gt;&lt;font style=&quot;font-size:11px;&quot;&gt;Prints:&lt;br&gt;&lt;font face=&quot;Consolas&quot;&gt;bastion_public_ip&lt;/font&gt;&lt;br&gt;&lt;font face=&quot;Consolas&quot;&gt;app_server_private_ip&lt;/font&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0d2137;strokeColor=#0096D6;strokeWidth=2;fontColor=#e0e0e0;arcSize=8;verticalAlign=top;spacingTop=4;spacingLeft=8;spacingRight=8;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="1320" y="670" width="260" height="150" as="geometry" />
        </mxCell>

        <!-- terraform.tfstate box below -->
        <mxCell id="s1_tfstate" value="&lt;font face=&quot;Consolas&quot;&gt;&lt;b&gt;terraform.tfstate&lt;/b&gt;&lt;/font&gt;&lt;hr size=&quot;1&quot; style=&quot;border-color:#0096D6;&quot;&gt;&lt;font style=&quot;font-size:11px;&quot;&gt;Terraform&#39;s memory of what exists in OCI&lt;br&gt;Maps each .tf resource to a real OCID&lt;br&gt;Never edit by hand — &lt;font face=&quot;Consolas&quot;&gt;terraform state&lt;/font&gt; commands only&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1a1a2e;strokeColor=#0096D6;strokeWidth=2;fontColor=#e0e0e0;arcSize=8;verticalAlign=top;spacingTop=4;spacingLeft=8;spacingRight=8;fontSize=13;dashed=1;dashPattern=8 4;" vertex="1" parent="1">
          <mxGeometry x="70" y="860" width="520" height="140" as="geometry" />
        </mxCell>

        <!-- Arrow from apply down to tfstate -->
        <mxCell id="s1_arrow_state" value="writes" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#0096D6;strokeWidth=2;fontColor=#b0b0b0;fontSize=11;fontFamily=Consolas;dashed=1;dashPattern=4 4;entryX=0.5;entryY=0;entryDx=0;entryDy=0;exitX=0.5;exitY=1;exitDx=0;exitDy=0;" edge="1" source="s1_apply" target="s1_tfstate" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1110" y="840" />
              <mxPoint x="330" y="840" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Flow indicators (chevron labels) -->
        <mxCell id="s1_flow_label" value="&lt;font color=&quot;#5bc0de&quot; style=&quot;font-size:11px;&quot;&gt;Infrastructure as Code pipeline &amp;mdash; declarative, idempotent, repeatable&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontColor=#5bc0de;fontFamily=Consolas;" vertex="1" parent="1">
          <mxGeometry x="660" y="830" width="530" height="26" as="geometry" />
        </mxCell>

        <!-- ============================================================ -->
        <!-- SECTION 2: TERRAFORM IMPORT vs GENERATE-CONFIG               -->
        <!-- ============================================================ -->

        <!-- Section 2 Container -->
        <mxCell id="s2_container" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#16213e;strokeColor=#7B68EE;strokeWidth=2;arcSize=4;" vertex="1" parent="1">
          <mxGeometry x="40" y="1060" width="2320" height="440" as="geometry" />
        </mxCell>

        <!-- Section 2 Title -->
        <mxCell id="s2_title" value="&lt;font style=&quot;font-size:18px;&quot;&gt;&lt;b&gt;SECTION 2: TERRAFORM IMPORT vs GENERATE-CONFIG&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontColor=#7B68EE;fontFamily=Consolas;" vertex="1" parent="1">
          <mxGeometry x="60" y="1070" width="600" height="30" as="geometry" />
        </mxCell>

        <!-- ===== PATH A: terraform import (Blue) ===== -->
        <mxCell id="s2_pathA_label" value="&lt;font style=&quot;font-size:14px;&quot; color=&quot;#0096D6&quot;&gt;&lt;b&gt;PATH A: &lt;font face=&quot;Consolas&quot;&gt;terraform import&lt;/font&gt;&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px;&quot;&gt;What you did (Step 11.10) &amp;mdash; learns the resource model&lt;/font&gt;&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="70" y="1110" width="480" height="50" as="geometry" />
        </mxCell>

        <!-- Path A Step 1 -->
        <mxCell id="s2a_step1" value="&lt;b&gt;1. Write .tf by hand&lt;/b&gt;&lt;hr size=&quot;1&quot; style=&quot;border-color:#0096D6;&quot;&gt;&lt;font face=&quot;Consolas&quot; style=&quot;font-size:11px;&quot;&gt;resource &quot;oci_core_vcn&quot; &quot;lab_vcn&quot; {&lt;br&gt;&amp;nbsp;&amp;nbsp;compartment_id = var.compartment_id&lt;br&gt;&amp;nbsp;&amp;nbsp;cidr_blocks = [&quot;10.0.0.0/16&quot;]&lt;br&gt;}&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0d2137;strokeColor=#0096D6;strokeWidth=2;fontColor=#e0e0e0;arcSize=8;verticalAlign=top;spacingTop=4;spacingLeft=8;spacingRight=8;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="70" y="1170" width="330" height="130" as="geometry" />
        </mxCell>

        <!-- Arrow A 1→2 -->
        <mxCell id="s2a_arrow1" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#0096D6;strokeWidth=2;" edge="1" source="s2a_step1" target="s2a_step2" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Path A Step 2 -->
        <mxCell id="s2a_step2" value="&lt;b&gt;2. Import existing OCID&lt;/b&gt;&lt;hr size=&quot;1&quot; style=&quot;border-color:#0096D6;&quot;&gt;&lt;font face=&quot;Consolas&quot; style=&quot;font-size:11px;&quot;&gt;terraform import \&lt;br&gt;&amp;nbsp;&amp;nbsp;oci_core_vcn.lab_vcn \&lt;br&gt;&amp;nbsp;&amp;nbsp;ocid1.vcn.oc1.iad...&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0d2137;strokeColor=#0096D6;strokeWidth=2;fontColor=#e0e0e0;arcSize=8;verticalAlign=top;spacingTop=4;spacingLeft=8;spacingRight=8;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="470" y="1170" width="330" height="130" as="geometry" />
        </mxCell>

        <!-- Arrow A 2→3 -->
        <mxCell id="s2a_arrow2" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#0096D6;strokeWidth=2;" edge="1" source="s2a_step2" target="s2a_step3" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Path A Step 3 -->
        <mxCell id="s2a_step3" value="&lt;b&gt;3. Fix drift &amp;amp; plan clean&lt;/b&gt;&lt;hr size=&quot;1&quot; style=&quot;border-color:#0096D6;&quot;&gt;&lt;font face=&quot;Consolas&quot; style=&quot;font-size:11px;&quot;&gt;terraform plan&lt;br&gt;# &quot;No changes&quot; = success&lt;br&gt;# Drift? Update .tf to match&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0d2137;strokeColor=#0096D6;strokeWidth=2;fontColor=#e0e0e0;arcSize=8;verticalAlign=top;spacingTop=4;spacingLeft=8;spacingRight=8;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="870" y="1170" width="280" height="130" as="geometry" />
        </mxCell>

        <!-- ===== PATH B: generate-config (Purple) ===== -->
        <mxCell id="s2_pathB_label" value="&lt;font style=&quot;font-size:14px;&quot; color=&quot;#9B59B6&quot;&gt;&lt;b&gt;PATH B: &lt;font face=&quot;Consolas&quot;&gt;terraform plan -generate-config-out&lt;/font&gt;&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px;&quot;&gt;Bulk migration tool (Terraform 1.5+) &amp;mdash; auto-generates code&lt;/font&gt;&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="1260" y="1110" width="520" height="50" as="geometry" />
        </mxCell>

        <!-- Path B Step 1 -->
        <mxCell id="s2b_step1" value="&lt;b&gt;1. Write import block only&lt;/b&gt;&lt;hr size=&quot;1&quot; style=&quot;border-color:#9B59B6;&quot;&gt;&lt;font face=&quot;Consolas&quot; style=&quot;font-size:11px;&quot;&gt;import {&lt;br&gt;&amp;nbsp;&amp;nbsp;to = oci_core_vcn.lab_vcn&lt;br&gt;&amp;nbsp;&amp;nbsp;id = &quot;ocid1.vcn.oc1...&quot;&lt;br&gt;}&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1a0a2e;strokeColor=#9B59B6;strokeWidth=2;fontColor=#e0e0e0;arcSize=8;verticalAlign=top;spacingTop=4;spacingLeft=8;spacingRight=8;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1260" y="1170" width="310" height="130" as="geometry" />
        </mxCell>

        <!-- Arrow B 1→2 -->
        <mxCell id="s2b_arrow1" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#9B59B6;strokeWidth=2;" edge="1" source="s2b_step1" target="s2b_step2" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Path B Step 2 -->
        <mxCell id="s2b_step2" value="&lt;b&gt;2. Terraform generates .tf&lt;/b&gt;&lt;hr size=&quot;1&quot; style=&quot;border-color:#9B59B6;&quot;&gt;&lt;font face=&quot;Consolas&quot; style=&quot;font-size:11px;&quot;&gt;terraform plan \&lt;br&gt;&amp;nbsp;&amp;nbsp;-generate-config-out=&lt;br&gt;&amp;nbsp;&amp;nbsp;generated.tf&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px;&quot;&gt;Auto-writes full resource blocks&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1a0a2e;strokeColor=#9B59B6;strokeWidth=2;fontColor=#e0e0e0;arcSize=8;verticalAlign=top;spacingTop=4;spacingLeft=8;spacingRight=8;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1640" y="1170" width="310" height="130" as="geometry" />
        </mxCell>

        <!-- Path B Step 3 -->
        <mxCell id="s2b_step3" value="&lt;b&gt;3. Review &amp;amp; refactor&lt;/b&gt;&lt;hr size=&quot;1&quot; style=&quot;border-color:#9B59B6;&quot;&gt;&lt;font style=&quot;font-size:11px;&quot;&gt;Clean up generated code&lt;br&gt;Add variables, format,&lt;br&gt;then &lt;font face=&quot;Consolas&quot;&gt;terraform apply&lt;/font&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1a0a2e;strokeColor=#9B59B6;strokeWidth=2;fontColor=#e0e0e0;arcSize=8;verticalAlign=top;spacingTop=4;spacingLeft=8;spacingRight=8;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="2010" y="1170" width="280" height="130" as="geometry" />
        </mxCell>

        <!-- Arrow B 2→3 -->
        <mxCell id="s2b_arrow2" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#9B59B6;strokeWidth=2;" edge="1" source="s2b_step2" target="s2b_step3" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- VS Divider -->
        <mxCell id="s2_vs" value="&lt;font style=&quot;font-size:22px;&quot; color=&quot;#FFC107&quot;&gt;&lt;b&gt;VS&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="1180" y="1220" width="50" height="40" as="geometry" />
        </mxCell>

        <!-- Comparison notes -->
        <mxCell id="s2_note_a" value="&lt;font style=&quot;font-size:11px;&quot; color=&quot;#0096D6&quot;&gt;&#10006; Manual — you write every attribute&lt;br&gt;&#10004; Deep learning — forces you to understand the resource model&lt;br&gt;&#10004; Best for interviews: &quot;I hand-wrote and imported 11 resources&quot;&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="70" y="1320" width="480" height="60" as="geometry" />
        </mxCell>

        <mxCell id="s2_note_b" value="&lt;font style=&quot;font-size:11px;&quot; color=&quot;#9B59B6&quot;&gt;&#10004; Fast — one block per resource, Terraform writes the rest&lt;br&gt;&#10004; Ideal for brownfield migrations (100+ resources)&lt;br&gt;&#10006; Generated code needs cleanup; less learning value&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="1260" y="1320" width="480" height="60" as="geometry" />
        </mxCell>

        <!-- Divider line between paths -->
        <mxCell id="s2_divider" value="" style="endArrow=none;dashed=1;html=1;strokeColor=#444444;strokeWidth=2;dashPattern=8 8;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1210" y="1110" as="sourcePoint" />
            <mxPoint x="1210" y="1480" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- ============================================================ -->
        <!-- SECTION 3: ANSIBLE WORKFLOW (Step 12) — Green theme          -->
        <!-- ============================================================ -->

        <!-- Section 3 Container -->
        <mxCell id="s3_container" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0a2e1a;strokeColor=#4CAF50;strokeWidth=2;arcSize=4;" vertex="1" parent="1">
          <mxGeometry x="40" y="1530" width="2320" height="500" as="geometry" />
        </mxCell>

        <!-- Section 3 Title -->
        <mxCell id="s3_title" value="&lt;font style=&quot;font-size:18px;&quot;&gt;&lt;b&gt;SECTION 3: ANSIBLE WORKFLOW (Step 12)&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontColor=#4CAF50;fontFamily=Consolas;" vertex="1" parent="1">
          <mxGeometry x="60" y="1540" width="480" height="30" as="geometry" />
        </mxCell>

        <!-- Step 1: inventory.ini -->
        <mxCell id="s3_inventory" value="&lt;b&gt;inventory.ini&lt;/b&gt;&lt;hr size=&quot;1&quot; style=&quot;border-color:#4CAF50;&quot;&gt;&lt;font face=&quot;Consolas&quot; style=&quot;font-size:10px;&quot;&gt;[bastion]&lt;br&gt;bastion_server ansible_host=&lt;b&gt;PUBLIC_IP&lt;/b&gt;&lt;br&gt;&lt;br&gt;[app]&lt;br&gt;app-server ansible_host=&lt;b&gt;PRIVATE_IP&lt;/b&gt;&lt;br&gt;&amp;nbsp;&amp;nbsp;ansible_ssh_common_args=&lt;br&gt;&amp;nbsp;&amp;nbsp;&#39;-o ProxyCommand=&quot;ssh -W %h:%p&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;opc@BASTION_IP&quot;&#39;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0d2e15;strokeColor=#4CAF50;strokeWidth=2;fontColor=#e0e0e0;arcSize=8;verticalAlign=top;spacingTop=4;spacingLeft=8;spacingRight=8;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="70" y="1590" width="340" height="190" as="geometry" />
        </mxCell>

        <!-- Arrow 1→2 -->
        <mxCell id="s3_arrow1" value="feeds" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#4CAF50;strokeWidth=2;fontColor=#81C784;fontSize=11;fontFamily=Consolas;" edge="1" source="s3_inventory" target="s3_harden" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Step 2: harden.yml -->
        <mxCell id="s3_harden" value="&lt;b&gt;harden.yml&lt;/b&gt;&lt;hr size=&quot;1&quot; style=&quot;border-color:#4CAF50;&quot;&gt;&lt;font style=&quot;font-size:11px;&quot;&gt;&lt;b&gt;20 tasks&lt;/b&gt; including:&lt;br&gt;SSH lockdown (no root, no passwords)&lt;br&gt;firewalld (ports 22, 8000)&lt;br&gt;auditd (STIG rules)&lt;br&gt;Kernel tuning (sysctl)&lt;br&gt;PAM password complexity&lt;br&gt;Fail2ban configuration&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0d2e15;strokeColor=#4CAF50;strokeWidth=2;fontColor=#e0e0e0;arcSize=8;verticalAlign=top;spacingTop=4;spacingLeft=8;spacingRight=8;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="490" y="1590" width="300" height="190" as="geometry" />
        </mxCell>

        <!-- Arrow 2→3 -->
        <mxCell id="s3_arrow2" value="then" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#4CAF50;strokeWidth=2;fontColor=#81C784;fontSize=11;fontFamily=Consolas;" edge="1" source="s3_harden" target="s3_deploy" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Step 3: deploy_app.yml -->
        <mxCell id="s3_deploy" value="&lt;b&gt;deploy_app.yml&lt;/b&gt;&lt;hr size=&quot;1&quot; style=&quot;border-color:#4CAF50;&quot;&gt;&lt;font style=&quot;font-size:11px;&quot;&gt;&lt;b&gt;10 tasks&lt;/b&gt; including:&lt;br&gt;Create &lt;font face=&quot;Consolas&quot;&gt;fedtracker&lt;/font&gt; service user&lt;br&gt;Install Python3 + pip&lt;br&gt;Copy &lt;font face=&quot;Consolas&quot;&gt;main.py&lt;/font&gt; + requirements&lt;br&gt;Create systemd unit file&lt;br&gt;Start &amp;amp; enable service&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0d2e15;strokeColor=#4CAF50;strokeWidth=2;fontColor=#e0e0e0;arcSize=8;verticalAlign=top;spacingTop=4;spacingLeft=8;spacingRight=8;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="870" y="1590" width="300" height="190" as="geometry" />
        </mxCell>

        <!-- Arrow 3→4 -->
        <mxCell id="s3_arrow3" value="result" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#4CAF50;strokeWidth=2;fontColor=#81C784;fontSize=11;fontFamily=Consolas;" edge="1" source="s3_deploy" target="s3_result" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Step 4: Running FedTracker API -->
        <mxCell id="s3_result" value="&lt;font color=&quot;#4CAF50&quot;&gt;&lt;b&gt;Running FedTracker API&lt;/b&gt;&lt;/font&gt;&lt;hr size=&quot;1&quot; style=&quot;border-color:#4CAF50;&quot;&gt;&lt;font face=&quot;Consolas&quot; style=&quot;font-size:11px;&quot;&gt;curl localhost:8000/health&lt;br&gt;{&quot;status&quot;: &quot;healthy&quot;}&lt;br&gt;&lt;br&gt;systemctl status fedtracker&lt;br&gt;Active: active (running)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1b3a1b;strokeColor=#4CAF50;strokeWidth=3;fontColor=#e0e0e0;arcSize=8;verticalAlign=top;spacingTop=4;spacingLeft=8;spacingRight=8;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1250" y="1590" width="300" height="190" as="geometry" />
        </mxCell>

        <!-- SSH Jump Diagram (below main flow) -->
        <mxCell id="s3_ssh_title" value="&lt;font style=&quot;font-size:13px;&quot; color=&quot;#81C784&quot;&gt;&lt;b&gt;SSH Jump Path (ProxyCommand)&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="70" y="1810" width="260" height="26" as="geometry" />
        </mxCell>

        <!-- Laptop -->
        <mxCell id="s3_laptop" value="&lt;b&gt;Laptop (WSL2)&lt;/b&gt;&lt;br&gt;&lt;font face=&quot;Consolas&quot; style=&quot;font-size:10px;&quot;&gt;ansible-playbook&lt;br&gt;-i inventory.ini&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0d2e15;strokeColor=#81C784;strokeWidth=2;fontColor=#e0e0e0;arcSize=12;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="70" y="1850" width="200" height="80" as="geometry" />
        </mxCell>

        <!-- Arrow laptop→bastion -->
        <mxCell id="s3_ssh1" value="&lt;font face=&quot;Consolas&quot; style=&quot;font-size:10px;&quot;&gt;SSH port 22&lt;br&gt;(public internet)&lt;/font&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#81C784;strokeWidth=2;fontColor=#81C784;fontSize=10;" edge="1" source="s3_laptop" target="s3_bastion_box" parent="1">
          <mxGeometry relative="1" as="geometry" />
